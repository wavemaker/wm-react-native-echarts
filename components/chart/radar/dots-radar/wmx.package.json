{
  "name": "dots-radar",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/radar/dots-radar"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-radar-dots-radar--docs",
  "displayName": "Dots Radar",
  "description": "Radar chart with circular markers highlighting each data point",
  "iconUrl": "wmx.icon.svg",
  "preview": [
    "wmx.preview.1.png"
  ],
  "component": "dots-radar.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wuba/react-native-echarts": "3.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "react-native-svg": "15.12.1",
    "echarts": "5.5.1",
    "zrender": "5.6.0"
  },
  "keywords": [
    "radar",
    "chart",
    "dots",
    "markers",
    "symbols",
    "points",
    "visualization",
    "highlighted",
    "chart/radar"
  ],
  "wmx": {
    "group": "chart/radar",
    "props": {
      "indicators": {
        "name": "indicators",
        "displayName": "Indicators",
        "description": "Array of indicators defining the radar axes. Example: [{name: 'Indicator 1', max: 100}, {name: 'Indicator 2', max: 100}]",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "data": {
        "name": "data",
        "displayName": "Data",
        "description": "Array of values corresponding to each indicator. Example: [100, 200, 150, 300]",
        "type": "number",
        "isList": true,
        "isRequired": true
      },
      "width": {
        "name": "width",
        "displayName": "Width",
        "description": "Width of the chart in pixels. Example: 220",
        "type": "number",
        "isList": false,
        "defaultValue": 220,
        "isRequired": false
      },
      "height": {
        "name": "height",
        "displayName": "Height",
        "description": "Height of the chart in pixels. Example: 350",
        "type": "number",
        "isList": false,
        "defaultValue": 300,
        "isRequired": false
      },
      "theme": {
        "name": "theme",
        "displayName": "Theme",
        "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
        "type": "object",
        "isList": false,
        "isRequired": false
      },
      "colors": {
        "name": "colors",
        "displayName": "Colors",
        "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
        "type": "string",
        "isList": true,
        "isRequired": false
      }
    },
    "webSupport": true
  }
}