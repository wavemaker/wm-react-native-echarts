{
  "name": "custom-label-line",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/line/custom-label-line"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-line-custom-label-line--docs",
  "displayName": "Custom Label Line",
  "description": "Line chart with custom text labels displayed next to data points",
  "iconUrl": "wmx.icon.svg",
  "preview": [
    "wmx.preview.1.png"
  ],
  "component": "custom-label-line.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wuba/react-native-echarts": "3.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "react-native-svg": "15.12.1",
    "echarts": "5.5.1",
    "zrender": "5.6.0"
  },
  "keywords": [
    "line",
    "chart",
    "labels",
    "custom",
    "annotated",
    "visualization",
    "markers",
    "text",
    "chart/line"
  ],
  "wmx": {
    "props": {
      "xAxisData": {
        "name": "xAxisData",
        "displayName": "X Axis Data",
        "description": "X-axis labels. Can be a string array or object array with label and value. Example: ['Jan', 'Feb', 'Mar'] or [{label: 'Jan', value: 0}, {label: 'Feb', value: 1}]",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "data": {
        "name": "data",
        "displayName": "Data",
        "description": "Array of data points with custom labels for each point. Example: [{value: 100, label: {formatter: 'Point 1'}}, {value: 200}]",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "width": {
        "name": "width",
        "displayName": "Width",
        "description": "Width of the chart in pixels. Example: 220",
        "type": "number",
        "isList": false,
        "defaultValue": 220,
        "isRequired": false
      },
      "height": {
        "name": "height",
        "displayName": "Height",
        "description": "Height of the chart in pixels. Example: 350",
        "type": "number",
        "isList": false,
        "defaultValue": 350,
        "isRequired": false
      },
      "lineWidth": {
        "name": "lineWidth",
        "displayName": "Line Width",
        "description": "Width of the line in pixels. Example: 2",
        "type": "number",
        "isList": false,
        "isRequired": false
      },
      "theme": {
        "name": "theme",
        "displayName": "Theme",
        "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
        "type": "object",
        "isList": false,
        "isRequired": false
      },
      "colors": {
        "name": "colors",
        "displayName": "Colors",
        "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
        "type": "string",
        "isList": true,
        "isRequired": false
      }
    },
    "webSupport": true
  }
}