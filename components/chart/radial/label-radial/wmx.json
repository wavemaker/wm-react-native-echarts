{
  "name": "label-radial",
  "displayName": "Label Radial",
  "description": "Circular radial bar chart with multiple categories arranged in polar coordinates",
  "group": "chart/radial",
  "files": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "packages": [
    "@wuba/react-native-echarts@3.0.1",
    "@shopify/react-native-skia@2.2.12",
    "react-native-svg@15.12.1",
    "echarts@5.5.1",
    "zrender@5.6.0"
  ],
  "tags": [
    "radial",
    "chart",
    "polar",
    "circular",
    "multi-category",
    "bars",
    "visualization",
    "progress"
  ],
  "props": {
    "data": {
      "name": "data",
