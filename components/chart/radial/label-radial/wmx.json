      "type": "object",
      "isList": true,
      "isRequired": true
    },
    "width": {
      "name": "width",
      "displayName": "Width",
      "description": "Width of the chart in pixels. Example: 220",
      "type": "number",
      "isList": false,
      "defaultValue": 220,
      "isRequired": false
    },
    "height": {
      "name": "height",
      "displayName": "Height",
      "description": "Height of the chart in pixels. Example: 350",
      "type": "number",
      "isList": false,
      "defaultValue": 350,
      "isRequired": false
    },
    "theme": {
      "name": "theme",
      "displayName": "Theme",
      "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
      "type": "object",
      "isList": false,
      "isRequired": false
    },
    "colors": {
      "name": "colors",
      "displayName": "Colors",
      "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
      "type": "string",
      "isList": true,
      "isRequired": false
    }
