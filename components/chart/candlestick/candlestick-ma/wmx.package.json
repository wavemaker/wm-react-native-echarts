{
  "name": "candlestick-ma",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/candlestick/candlestick-ma"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-candlestick-candlestick-ma--docs",
  "displayName": "Candlestick MA",
  "description": "Candlestick chart with moving average lines (MA5, MA10, MA20) and legend for technical analysis",
  "iconUrl": "wmx.icon.svg",
  "preview": [
    "wmx.preview.1.png"
  ],
  "component": "candlestick-ma.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wuba/react-native-echarts": "3.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "react-native-svg": "15.12.1",
    "echarts": "5.5.1",
    "zrender": "5.6.0"
  },
  "keywords": [
    "candlestick",
    "chart",
    "moving-average",
    "technical-analysis",
    "stock",
    "financial",
    "ma",
    "overlay",
    "visualization",
    "trading",
    "chart/candlestick"
  ],
  "wmx": {
    "group": "chart/candlestick",
    "props": {
      "xAxisData": {
        "name": "xAxisData",
        "displayName": "X Axis Data",
        "description": "Array of date/time labels for the X-axis. Example: ['Jan', 'Feb', 'Mar']",
        "type": "string",
        "isList": true,
        "isRequired": true
      },
      "width": {
        "name": "width",
        "displayName": "Width",
        "description": "Width of the chart in pixels. Example: 220",
        "type": "number",
        "isList": false,
        "defaultValue": 220,
        "isRequired": false
      },
      "height": {
        "name": "height",
        "displayName": "Height",
        "description": "Height of the chart in pixels. Example: 350",
        "type": "number",
        "isList": false,
        "defaultValue": 450,
        "isRequired": false
      },
      "theme": {
        "name": "theme",
        "displayName": "Theme",
        "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
        "type": "object",
        "isList": false,
        "isRequired": false
      },
      "colors": {
        "name": "colors",
        "displayName": "Colors",
        "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
        "type": "string",
        "isList": true,
        "isRequired": false
      },
      "priceData": {
        "name": "priceData",
        "displayName": "Price Data",
        "description": "Array of OHLC price data. Each item is [open, close, low, high]. Example: [[100, 110, 95, 120], [110, 105, 100, 115]]",
        "type": "number",
        "isList": true,
        "isRequired": true
      },
      "ma5Data": {
        "name": "ma5Data",
        "displayName": "MA5 Data",
        "description": "5-period moving average data. Example: [105, 107, 106, 108]",
        "type": "number",
        "isList": true,
        "isRequired": true
      },
      "ma10Data": {
        "name": "ma10Data",
        "displayName": "MA10 Data",
        "description": "10-period moving average data. Example: [102, 104, 103, 105]",
        "type": "number",
        "isList": true,
        "isRequired": true
      },
      "ma20Data": {
        "name": "ma20Data",
        "displayName": "MA20 Data",
        "description": "20-period moving average data. Example: [100, 101, 102, 103]",
        "type": "number",
        "isList": true,
        "isRequired": true
      }
    },
    "webSupport": true
  }
}