{
  "name": "candlestick-chart",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/candlestick"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-candlestick-candlestickchart--docs",
  "displayName": "Candlestick Chart",
  "description": "Candlestick (OHLC) chart with optional volume bars and moving averages (MA5, MA10, MA20)",
  "iconUrl": "wmx.icon.svg",
  "preview": [],
  "component": "candlestick-chart.tsx",
  "requires": [
    "../candlestick-chart.tsx",
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wuba/react-native-echarts": "3.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "react-native-svg": "15.12.1",
    "echarts": "5.5.1",
    "zrender": "5.6.0"
  },
  "keywords": [
    "candlestick",
    "k-line",
    "ohlc",
    "chart",
    "volume",
    "moving average",
    "chart/candlestick"
  ],
  "wmx": {
    "group": "chart/candlestick",
    "props": {
      "data": {
        "name": "data",
        "displayName": "Data",
        "description": "Candlestick data: array of [open, close, low, high] per period.",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "xAxisData": {
        "name": "xAxisData",
        "displayName": "X Axis Data",
        "description": "X-axis category labels. Example: ['Mon', 'Tue', 'Wed']",
        "type": "object",
        "isList": true,
        "isRequired": false
      },
      "volumeData": {
        "name": "volumeData",
        "displayName": "Volume Data",
        "description": "Optional volume data (bar series below candlestick).",
        "type": "object",
        "isList": true,
        "isRequired": false
      },
      "ma5": {
        "name": "ma5",
        "displayName": "MA5",
        "description": "Optional 5-period moving average line data.",
        "type": "object",
        "isList": true,
        "isRequired": false
      },
      "ma10": {
        "name": "ma10",
        "displayName": "MA10",
        "description": "Optional 10-period moving average line data.",
        "type": "object",
        "isList": true,
        "isRequired": false
      },
      "ma20": {
        "name": "ma20",
        "displayName": "MA20",
        "description": "Optional 20-period moving average line data.",
        "type": "object",
        "isList": true,
        "isRequired": false
      },
      "width": {
        "name": "width",
        "displayName": "Width",
        "description": "Width of the chart in pixels.",
        "type": "number",
        "isList": false,
        "defaultValue": 220,
        "isRequired": false
      },
      "height": {
        "name": "height",
        "displayName": "Height",
        "description": "Height of the chart in pixels.",
        "type": "number",
        "isList": false,
        "defaultValue": 350,
        "isRequired": false
      },
      "showLegend": {
        "name": "showLegend",
        "displayName": "Show Legend",
        "description": "Whether to display legend for moving averages.",
        "type": "boolean",
        "isList": false,
        "defaultValue": false,
        "isRequired": false
      }
    },
    "webSupport": true
  }
}
