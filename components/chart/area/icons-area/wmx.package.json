{
  "name": "icons-area",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboyina/rn-widgets/tree/0.0.0-dev/components/chart/area/icons-area"
  },
  "homepage": "https://rn-charts.storybook.wavemaker.com/?path=/docs/charts-area-icons-area--docs",
  "displayName": "Icons Area",
  "description": "Area chart with data point markers and tooltip support for tracking values",
  "iconUrl": "wmx.icon.svg",
  "preview": [
    "wmx.preview.1.png"
  ],
  "component": "icons-area.chart.tsx",
  "requires": [
    "../../chart-container.tsx",
    "../../chart-theme.context.tsx"
  ],
  "dependencies": {
    "@wuba/react-native-echarts": "3.0.1",
    "@shopify/react-native-skia": "2.2.12",
    "react-native-svg": "15.12.1",
    "echarts": "5.5.1",
    "zrender": "5.6.0"
  },
  "keywords": [
    "area",
    "chart",
    "markers",
    "icons",
    "tooltip",
    "data-points",
    "visualization",
    "interactive",
    "chart/line/area"
  ],
  "wmx": {
    "group": "chart/line/area",
    "props": {
      "xAxisData": {
        "name": "xAxisData",
        "displayName": "X Axis Data",
        "description": "X-axis labels. Can be a string array or object array with label and value. Example: ['Jan', 'Feb', 'Mar'] or [{label: 'Jan', value: 0}, {label: 'Feb', value: 1}]",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "data": {
        "name": "data",
        "displayName": "Data",
        "description": "Array of named data series. Each series has a name and data array. Example: [{name: 'Series 1', data: [100, 200, 150]}]",
        "type": "object",
        "isList": true,
        "isRequired": true
      },
      "width": {
        "name": "width",
        "displayName": "Width",
        "description": "Width of the chart in pixels. Example: 220",
        "type": "number",
        "isList": false,
        "defaultValue": 220,
        "isRequired": false
      },
      "height": {
        "name": "height",
        "displayName": "Height",
        "description": "Height of the chart in pixels. Example: 350",
        "type": "number",
        "isList": false,
        "defaultValue": 350,
        "isRequired": false
      },
      "theme": {
        "name": "theme",
        "displayName": "Theme",
        "description": "Partial theme override for customizing chart appearance. Example: {series: [{color: '#3b82f6'}]}",
        "type": "object",
        "isList": false,
        "isRequired": false
      },
      "colors": {
        "name": "colors",
        "displayName": "Colors",
        "description": "Colors for the chart. Example: ['#3b82f6', '#10b981', '#f59e0b']",
        "type": "string",
        "isList": true,
        "isRequired": false
      }
    },
    "webSupport": true
  }
}