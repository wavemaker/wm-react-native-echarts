{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist/npm-packages/charts",
    "rootDir": "components/chart",
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@/contexts/ThemeContext": ["./components/lib-theme-context"]
    }
  },
  "include": ["components/**/*.ts", "components/**/*.tsx"],
  "exclude": ["**/wmx/**", "**/*.stories.*", "**/*.test.*", "**/*.spec.*", "components/theme-toggle.tsx"]
}
